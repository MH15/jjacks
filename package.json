{
  "name": "jjacks",
  "version": "0.1.2",
  "description": "Sync a jj bookmark stack with GitHub pull requests.",
  "homepage": "https://github.com/MH15/jjacks#readme",
  "bugs": {
    "url": "https://github.com/MH15/jjacks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MH15/jjacks.git"
  },
  "bin": {
    "jjacks": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "scripts/telemetry-report.ts"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup --config tsup.config.ts && chmod +x dist/cli.js",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "format": "oxfmt src scripts *.ts *.json AGENTS.md README.md docs notes",
    "format:check": "oxfmt --check src scripts *.ts *.json AGENTS.md README.md docs notes",
    "lint": "oxlint --deny-warnings src scripts *.ts",
    "prepack": "npm run build",
    "start": "node --enable-source-maps dist/cli.js",
    "test": "vitest run --exclude 'src/integration/**/*.integration.test.ts'",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "telemetry:report": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/telemetry-report.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform-node": "^0.107.0",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "effect": "^3.21.2",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.68.0",
    "tsup": "^8.3.6",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
