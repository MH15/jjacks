{
  "name": "jjacks",
  "version": "0.1.0",
  "private": true,
  "description": "Sync a jj bookmark stack with GitHub pull requests.",
  "type": "module",
  "bin": {
    "jjacks": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && chmod +x dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node --enable-source-maps dist/cli.js",
    "test": "vitest run",
    "typecheck": "npm run check"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform-node": "^0.106.0",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "effect": "^3.21.2",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.3.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
